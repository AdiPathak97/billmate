# ─── MongoDB ────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/billmate

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── API ────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development

# ─── Web ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── File Storage ───────────────────────────────────────────
# Local path for dev; swap for S3-compatible config in prod
UPLOAD_DIR=./uploads
# STORAGE_PROVIDER=s3
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ─── Demo Mode ──────────────────────────────────────────────
DEMO_RESET_CRON=0 0 * * *   # midnight daily
